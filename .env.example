# Public client-side variables only (bundled into the browser).
# Do NOT put notification API keys or other secrets here.

# --- Supabase (admin auth + blog) — publishable key only; security via RLS + app_metadata.role ---
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Required on Netlify at build time (scope All) for RSS, sitemap, and OG shell generation.
# Same vars are used at runtime for blog and admin UI.

# --- Analytics (set in Netlify: Site configuration → Environment variables) ---
# Choose one provider:
# VITE_ANALYTICS_PROVIDER=plausible
# VITE_ANALYTICS_PROVIDER=ga4

# Plausible: site domain as registered in Plausible (e.g. enrollifyedu.com)
# GA4: Measurement ID (e.g. G-XXXXXXXXXX)
# VITE_ANALYTICS_ID=your-domain-or-measurement-id

# Log analytics events to the browser console in production (for smoke testing only)
# VITE_ANALYTICS_DEBUG=true

# Optional — RLS verification script only (never VITE_ prefix)
# SUPABASE_TEST_ADMIN_EMAIL=
# SUPABASE_TEST_ADMIN_PASSWORD=
# Do NOT add backend secrets here. They belong in apps/backend/.env or Railway env.

# --- Website chat widget (default enabled; set false to hide) ---
# VITE_CHAT_ENABLED=false

# --- Netlify admin API proxy (server-side build env, not VITE_) ---
# BACKEND_URL=https://your-backend.up.railway.app

# --- Form notifications (Netlify dashboard only — not a VITE_ variable) ---
# Configure under: Site configuration → Forms → Form notifications
# Recommended recipients (confirm with founders):
#   provider-contact  → hello@enrollifyedu.com
#   student-interest  → hello@enrollifyedu.com
