# Server
PORT=3001

# Meta Messenger (Phase 4)
FB_PAGE_ACCESS_TOKEN=dev-placeholder
FB_VERIFY_TOKEN=dev-placeholder
FB_APP_SECRET=dev-placeholder

# Perplexity API — optional; auto-seeds first provider if DB is empty
PERPLEXITY_API_KEY=dev-placeholder
PERPLEXITY_MODEL=sonar-pro
AI_REQUEST_TIMEOUT_MS=8000

# Encrypts AI provider API keys stored in Supabase (min 32 chars)
AI_PROVIDER_ENCRYPTION_KEY=dev-local-ai-encryption-key-32ch

# Supabase — server-only; never prefix with VITE_
SUPABASE_URL=https://lissrpaczvrvcolrxafx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Admin panel JWT
JWT_SECRET=dev-local-jwt-secret-min-32-chars!!
JWT_EXPIRES_IN=8h
ADMIN_EMAIL=admin@enrollifyedu.com
ADMIN_PASSWORD=changeme

# Admin frontend origin (CORS)
CORS_ORIGIN=http://localhost:3000
