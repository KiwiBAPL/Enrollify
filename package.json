{
  "name": "enrollify",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run generate:feeds",
    "generate:feeds": "tsx scripts/generate-feeds.ts",
    "verify:feeds": "tsx scripts/verify-feeds.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "tsx scripts/verify-rls.ts && tsx scripts/verify-feeds.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "netlify:dev": "netlify dev"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.1",
    "dompurify": "^3.4.11",
    "fuse.js": "^7.4.2",
    "quill": "^2.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^3.0.0",
    "react-quill-new": "^3.8.3",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.9",
    "ws": "^8.18.0"
  }
}
